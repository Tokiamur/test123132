end

simulateTradeRequest = function(senderName)
    senderName = trimText(senderName)
    if senderName == "" then
        showToast("Enter a player name first!", true)
        return false
    end

    mockState.currentTradeRequest = {
        partner = senderName,
        timestamp = tick(),
    }
    tradeHubSession.Active = true
    tradeHubSession.TargetName = senderName
    tradeHubSession.Accepted = false
    tradeHubSession.Countdown = 0
    updateTradeHubUI()

    showToast("Trade request prepared for " .. senderName)
    return true
end

autoAcceptTradeRequest = function()
    if not mockState.currentTradeRequest then
        showToast("No active Trade Request", true)
        return false
    end

    initTradeSystem()
    hookTradeEvents()

    task.wait(CONFIG.AUTO_ACCEPT_DELAY)

    if TradeRemote and TradeRemote:FindFirstChild("AcceptRequest") then
        pcall(function()
            TradeRemote.AcceptRequest:FireServer()
        end)
    end

    mockState.tradeActive = true
    mockState.tradePartner = mockState.currentTradeRequest.partner
    mockState.currentTradeRequest = nil
    tradeHubSession.Accepted = true
    tradeHubSession.Countdown = 0
    updateTradeHubUI()
    openRealTradeGUI()

    return true
end

autoConfirmTrade = function()
    if not mockState.tradeActive then
        return false
    end

    initTradeSystem()

    task.wait(CONFIG.AUTO_CONFIRM_DELAY)

    if TradeRemote and TradeRemote:FindFirstChild("AcceptTrade") then
        pcall(function()
            TradeRemote.AcceptTrade:FireServer(game.PlaceId * 3, mockState.lastOffer)
        end)
    end

    mockState.tradeActive = false
    mockState.tradePartner = nil
    mockState.lastOffer = nil
    tradeHubSession.Active = false
    tradeHubSession.TargetName = ""
    tradeHubSession.Accepted = false
    tradeHubSession.Countdown = 0
    updateTradeHubUI()

    return true
end

hookTradeEvents = function()
    if tradeEventsHooked then
        return
    end
    initTradeSystem()
    if not TradeRemote then
        return
    end
    tradeEventsHooked = true

    local startTrade = TradeRemote:FindFirstChild("StartTrade")
    if startTrade and startTrade.OnClientEvent then
        startTrade.OnClientEvent:Connect(function(tradeState, partnerName)
            mockState.tradeActive = true
            mockState.tradePartner = partnerName
            mockState.currentTradeRequest = nil
            mockState.lastOffer = tradeState and tradeState.LastOffer or nil
            tradeHubSession.Active = true
            tradeHubSession.TargetName = partnerName or tradeHubSession.TargetName
            tradeHubSession.Accepted = true
            tradeHubSession.Countdown = 0
            updateTradeHubUI()
            openRealTradeGUI()
        end)
    end

    local updateTrade = TradeRemote:FindFirstChild("UpdateTrade")
    if updateTrade and updateTrade.OnClientEvent then
        updateTrade.OnClientEvent:Connect(function(tradeState)
            if tradeState then
                mockState.lastOffer = tradeState.LastOffer
            end
        end)
    end

    local declineTrade = TradeRemote:FindFirstChild("DeclineTrade")
    if declineTrade and declineTrade.OnClientEvent then
        declineTrade.OnClientEvent:Connect(function()
            mockState.tradeActive = false
            mockState.tradePartner = nil
            mockState.currentTradeRequest = nil
            mockState.lastOffer = nil
            resetTradeHubSession()
        end)
    end

    local acceptTrade = TradeRemote:FindFirstChild("AcceptTrade")
    if acceptTrade and acceptTrade.OnClientEvent then
        acceptTrade.OnClientEvent:Connect(function(success)
            if success then
                showToast("Trade completed successfully!")
            end
            mockState.tradeActive = false
            mockState.tradePartner = nil
            mockState.currentTradeRequest = nil
            mockState.lastOffer = nil
            resetTradeHubSession()
        end)
    end
end

