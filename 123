local function waitForTradeGUI()
    local pg = player and player:FindFirstChild("PlayerGui") or nil
    if not pg then
        pg = player:WaitForChild("PlayerGui")
    end
    for _ = 1, 50 do
        local gui = pg:FindFirstChild("TradeGUI")
        if gui then
            return gui
        end
        task.wait(0.1)
    end
    return nil
end

initTradeSystem = function()
    if not TradeModule then
        pcall(function()
            TradeModule = waitForTradeModule()
        end)
    end
    if not TradeGUI then
        pcall(function()
            TradeGUI = waitForTradeGUI()
        end)
    end
    if not TradeRemote then
        pcall(function()
            TradeRemote = getTradeRemote()
        end)
    end
    return TradeModule ~= nil or TradeGUI ~= nil or TradeRemote ~= nil
end

openRealTradeGUI = function()
    initTradeSystem()
    hookTradeEvents()

    if not TradeGUI or not TradeGUI:FindFirstChild("Container") then
        return false
    end

    local container = TradeGUI.Container
    TradeGUI.Enabled = true

    local items = container:FindFirstChild("Items")
