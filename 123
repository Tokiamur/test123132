local function updateTradeHubUI()
    if tradeHubTargetLabel then
        if tradeHubSession.Active then
            tradeHubTargetLabel.Text = "Target: @" .. tradeHubSession.TargetName
        else
            tradeHubTargetLabel.Text = "Target: none"
        end
    end

    if tradeHubStatusLabel then
        if tradeHubSession.Active then
            tradeHubStatusLabel.Text = tradeHubSession.Accepted and "Status: accepted locally" or "Status: request sent"
        else
            tradeHubStatusLabel.Text = "Status: idle"
        end
    end

    if tradeHubTimerLabel then
        if tradeHubSession.Countdown > 0 then
            tradeHubTimerLabel.Text = "Timer: " .. tradeHubSession.Countdown .. "s"
        elseif tradeHubSession.Active then
            tradeHubTimerLabel.Text = tradeHubSession.Accepted and "Timer: done" or "Timer: ready"
        else
            tradeHubTimerLabel.Text = "Timer: idle"
        end
    end

    if tradeHubAcceptBtn then
        if tradeHubSession.Accepted then
            tradeHubAcceptBtn.Text = "ACCEPTED"
            tradeHubAcceptBtn.Active = false
            tradeHubAcceptBtn.AutoButtonColor = false
        elseif tradeHubSession.Active then
            tradeHubAcceptBtn.Text = tradeHubSession.Countdown > 0 and ("ACCEPT (" .. tradeHubSession.Countdown .. ")") or "ACCEPT"
            tradeHubAcceptBtn.Active = true
        else
            tradeHubAcceptBtn.Text = "ACCEPT"
            tradeHubAcceptBtn.Active = false
        end
    end
end

local function resetTradeHubSession()
    tradeHubCountdownToken += 1
    tradeHubSession.Active = false
    tradeHubSession.TargetName = ""
    tradeHubSession.Accepted = false
    tradeHubSession.Countdown = 0
    updateTradeHubUI()
end

local function startLocalTradeSession()
    local target = trimText(tradeHubTargetBox and tradeHubTargetBox.Text or "")
    if target == "" then
        showToast("Enter a player name first!", true)
        return false
    end
    tradeHubCountdownToken += 1
    tradeHubSession.Active = true
    tradeHubSession.TargetName = target
    tradeHubSession.Accepted = false
    tradeHubSession.Countdown = 0
    updateTradeHubUI()
    if mockState then
        mockState.currentTradeRequest = {
            partner = target,
            timestamp = tick(),
        }
    end
    showToast("Local request prepared for " .. target)
    return true
end

local function acceptLocalTrade()
    if not tradeHubSession.Active then
        showToast("Start a local request first!", true)
        return
    end
    if tradeHubSession.Accepted then
        return
    end

    tradeHubCountdownToken += 1
    local token = tradeHubCountdownToken

    task.spawn(function()
        for i = 5, 1, -1 do
            if token ~= tradeHubCountdownToken then
                return
            end
            tradeHubSession.Countdown = i
            updateTradeHubUI()
            task.wait(1)
        end

        if token ~= tradeHubCountdownToken then
            return
        end

        tradeHubSession.Countdown = 0
        tradeHubSession.Accepted = true
        updateTradeHubUI()
        showLocalTradePanels()
        if tradeHubFrame then
            tradeHubFrame.Visible = false
        end
        showToast("Local trade accepted for " .. tradeHubSession.TargetName)
    end)
end

