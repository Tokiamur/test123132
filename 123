refreshTheirPicker = function(text)
    text = (text or theirSearchBox.Text or ""):lower()
    local visible = 0
    for _, d in ipairs(theirButtons) do
        local show = text == "" or d.item.custom:lower():find(text, 1, true)
        d.row.Visible = show
        if show then
            visible += 1
            d.row.LayoutOrder = visible
        end
    end
    theirScroll.CanvasSize = UDim2.new(0, 0, 0, visible * 40 + 12)
    theirPickerCount.Text = visible == #items and ("All items  |  " .. #items .. " total") or (visible .. " of " .. #items .. " found")
end

