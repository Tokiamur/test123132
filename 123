    state.Weapons = {}
    state.Pets = {}
    state.Misc = {}

    for _, slot in ipairs(slots) do
        state[slot.ItemType] = state[slot.ItemType] or {}
        state[slot.ItemType][slot.Key] = slot.Amount
    end
